# ========== セキュリティ最重要 ==========
# サービスアカウントキー（絶対にコミットしない）
secrets/
*.json
!dbt/dbt_project.yml
!dbt/packages.yml
!repomix.config.json

# Streamlit シークレット
streamlit/.streamlit/secrets.toml

# dbt 接続情報
profiles.yml

# 環境変数ファイル
.env
.env.*
!.env.example

# ========== ビルド成果物 ==========
# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
.venv/

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml
dbt/package-lock.yml

# Elementary
edr_target/

# Repomix
repomix-output.*

# ワークログ（ポートフォリオ用に除外）
# docs/work_logs/

# ========== IDE ==========
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ========== テスト ==========
.coverage
htmlcov/
.pytest_cache/

