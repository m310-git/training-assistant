    OPTIONS()
    as (
      

SELECT * FROM UNNEST([
    STRUCT('chest'    AS body_part_id, '胸'    AS body_part_name, 'Monday'    AS training_day, 1 AS sort_order),
    STRUCT('back'     AS body_part_id, '背中'   AS body_part_name, 'Tuesday'   AS training_day, 2 AS sort_order),
