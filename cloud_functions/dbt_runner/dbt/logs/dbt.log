[0m23:50:25.336508 [debug] [Thread-1 (]: On model.training_assistant.stg_training_log: /* {"app": "dbt", "dbt_version": "1.11.6", "profile_name": "training_assistant", "target_name": "dev", "node_id": "model.training_assistant.stg_training_log"} */

  
    

    create or replace table `training-assistant-prod`.`staging_staging`.`stg_training_log`
      
    partition by date_trunc(training_date, month)
    

    OPTIONS()
    as (
      

WITH source AS (
    SELECT * FROM `training-assistant-prod`.`raw`.`training_log`
    
),

-- 重複排除（同一log_idで最新のものを採用）
deduplicated AS (
    SELECT
        *,
        ROW_NUMBER() OVER (
            PARTITION BY log_id
            ORDER BY created_at DESC
        ) AS row_num
    FROM source
),

cleaned AS (
    SELECT
        -- PK
        log_id,

        -- FK
        user_id,
        LOWER(TRIM(exercise_name))  AS exercise_name,
        LOWER(TRIM(body_part))      AS body_part,

        -- メジャー
        training_date,
        ROUND(weight_kg, 1)         AS weight_kg,
        reps,
        sets,

        -- 計算列: ボリューム = 重量 × レップ × セット
        ROUND(weight_kg * reps * sets, 1) AS volume,

        -- RPE（範囲外はNULLに）
        CASE
            WHEN rpe BETWEEN 6.0 AND 10.0 THEN ROUND(rpe, 1)
            ELSE NULL
        END AS rpe,

        memo,
        created_at

    FROM deduplicated
    WHERE row_num = 1
)

SELECT * FROM cleaned
    );
  
