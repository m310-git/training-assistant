    create or replace table `training-assistant-prod`.`mart`.`m_ml_suggestion`
      
    
    

    OPTIONS()
    as (
      

WITH latest_per_set AS (
    SELECT
        user_id,
        exercise_id,
        exercise_name,
        set_number,
        weight_kg,
        reps,
        rpe,
        volume,
