    create or replace table `training-assistant-prod`.`staging_mart`.`m_calendar`
      
    
    

    OPTIONS()
    as (
      
WITH set_summary AS (
    SELECT
        user_id,
        training_date,
        body_part_name,
        exercise_name,
        weight_kg
    FROM `training-assistant-prod`.`staging_mart`.`fct_training_set`
),
exercise_labels AS (
    SELECT DISTINCT
        user_id,
        training_date,
        CONCAT(exercise_name, ': ', CAST(weight_kg AS STRING), 'kg') AS label
    FROM set_summary
)
SELECT
    s.user_id,
    s.training_date,
    STRING_AGG(DISTINCT s.body_part_name, ', ') AS body_parts,
    SUM(f.volume) AS total_volume,
    COUNT(DISTINCT f.exercise_id) AS exercise_count,
    (
        SELECT STRING_AGG(label, ' / ')
        FROM (
            SELECT DISTINCT label
            FROM exercise_labels e
            WHERE e.user_id = s.user_id
              AND e.training_date = s.training_date
            ORDER BY label
        )
    ) AS exercise_summary
FROM set_summary s
JOIN `training-assistant-prod`.`staging_mart`.`fct_training_set` f
    ON s.user_id = f.user_id
    AND s.training_date = f.training_date
    AND s.exercise_name = f.exercise_name
    AND s.weight_kg = f.weight_kg
GROUP BY s.user_id, s.training_date
    );
  
