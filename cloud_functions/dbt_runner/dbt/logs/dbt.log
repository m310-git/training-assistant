    create or replace table `training-assistant-prod`.`staging_mart`.`m_ranking_bodypart`
      
    
    

    OPTIONS()
    as (
      

WITH weekly AS (
    SELECT
        f.user_id,
        u.user_name,
        f.body_part_id,
        bp.body_part_name,
        'weekly' AS period_type,
        DATE_TRUNC(f.training_date, WEEK(MONDAY)) AS period_start,
        SUM(f.volume) AS total_volume
    FROM `training-assistant-prod`.`staging_mart`.`fct_training_set` f
