{
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown"
  },
  "ignore": {
    "patterns": [
      "venv/**",
      ".venv/**",
      "dbt/target/**",
      "dbt/dbt_packages/**",
      "dbt/logs/**",
      "edr_target/**",
      "*.xml",
      "repomix-output.*",
      "secrets/**",
      "streamlit/.streamlit/secrets.toml",
      ".git/**",
      "__pycache__/**",
      "*.egg-info/**",
      ".pytest_cache/**",
      ".coverage",
      "htmlcov/**",
      "*.pyc",
      "node_modules/**",
      "docs/work_logs/**"
    ]
  },
  "removeComments": false,
  "removeEmptyLines": false,
  "topFilesLen": 10
}
