{
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown"
  },
  "ignore": {
    "patterns": [
      "venv",
      ".venv",
      "dbt/target",
      "dbt/dbt_packages",
      "dbt/logs",
      "edr_target",
      "*.xml",
      "repomix-output.*",
      "secrets",
      "streamlit/.streamlit/secrets.toml",
      ".git",
      "__pycache__",
      "*.egg-info",
      ".pytest_cache",
      ".coverage",
      "htmlcov",
      "*.pyc",
      "node_modules"
    ]
  },
  "removeComments": true,
  "removeEmptyLines": true,
  "topFilesLen": 10
}
