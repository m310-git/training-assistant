{
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown"
  },
  "include": [
    "streamlit/**/*.py",
    "cloud_functions/**/*.py",
    "dbt/models/**/*.sql",
    "dbt/macros/**/*.sql",
    "prefect_flows/**/*.py",
    "dbt/dbt_project.yml",
    "dbt/packages.yml",
    "requirements.txt",
    ".env.example",
    ".windsurfrules",
    ".gitignore",
    "README.md",
    "docs/design.md",
    "docs/data_dictionary.md"
  ],
  "ignore": {
    "patterns": [
      "venv",
      ".venv",
      "dbt/target",
      "dbt/dbt_packages",
      "dbt/logs",
      "edr_target",
      "*.xml",
      "repomix-output.*",
      "secrets",
      "streamlit/.streamlit/secrets.toml",
      ".git",
      "__pycache__",
      "*.egg-info",
      ".pytest_cache",
      ".coverage",
      "htmlcov",
      "*.pyc",
      "node_modules"
    ]
  },
  "removeComments": true,
  "removeEmptyLines": true,
  "topFilesLen": 10
}
